---
// Compact footer: brand + browse links (live calculators) + legal.
import { SITE } from "../data/site";
import { liveCalculators } from "../data/calculators";
const calcs = liveCalculators();
const year = 2026;
---
<footer class="site-footer">
  <div class="ftr-inner">
    <div class="ftr-left">
      <a class="brand" href="/" aria-label={`${SITE.name} home`}>
        <svg viewBox="0 0 32 32" width="22" height="22" aria-hidden="true">
          <rect width="32" height="32" rx="7" fill="var(--primary)"></rect>
          <rect x="8" y="6" width="16" height="20" rx="2.4" fill="none" stroke="#fff" stroke-width="2"></rect>
          <rect x="11" y="9.5" width="10" height="4" rx="1" fill="#fff"></rect>
          <circle cx="12.2" cy="18" r="1.3" fill="#fff"></circle>
          <circle cx="16" cy="18" r="1.3" fill="#fff"></circle>
        </svg>
        <span>{SITE.name}</span>
      </a>
      <p class="tagline">{SITE.description}</p>
    </div>

    <nav class="ftr-links" aria-label="Footer">
      <span class="grp-title">Calculators</span>
      <div class="links-grid">
        <a href="/calculators/">All calculators</a>
        {calcs.map((c) => <a href={`/${c.id}/`}>{c.label}</a>)}
      </div>
    </nav>
  </div>

  <div class="ftr-legal">
    <div class="legal-left">
      <span>© {year} {SITE.name}</span>
      <span class="dot">·</span>
      <span>For educational purposes — not financial advice.</span>
    </div>
    <div class="legal-right">
      <a href="/about/">About</a>
      <span class="dot">·</span>
      <span>Powered by <a href="https://www.layer3labs.io" target="_blank" rel="noopener noreferrer">Layer3Labs</a></span>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: #0E1A16; color: #C2D2CC; margin-top: 48px; }
  .ftr-inner {
    max-width: 1000px; margin: 0 auto; padding: 28px 20px 22px;
    display: flex; gap: 32px 48px; flex-wrap: wrap; align-items: flex-start;
  }
  .ftr-left { max-width: 320px; }
  .brand { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: #fff; }
  .brand span { font-size: 1.05rem; font-weight: 800; letter-spacing: -0.02em; }
  .tagline { font-size: 0.85rem; line-height: 1.5; color: #7B948C; margin: 8px 0 0; }
  .ftr-links { margin-left: auto; }
  .grp-title { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: #5A726A; font-weight: 700; margin-bottom: 10px; }
  .links-grid {
    display: grid; grid-auto-flow: column; grid-template-rows: repeat(4, auto);
    gap: 8px 48px;
  }
  .links-grid a { color: #C2D2CC; text-decoration: none; font-size: 0.88rem; white-space: nowrap; }
  .links-grid a:hover { color: #fff; }
  .ftr-legal {
    border-top: 1px solid #1C2A24;
    max-width: 1000px; margin: 0 auto; padding: 14px 20px;
    display: flex; justify-content: space-between; gap: 8px 18px; flex-wrap: wrap;
    font-size: 0.78rem; color: #5A726A;
  }
  .legal-left, .legal-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .ftr-legal .dot { color: #33433C; }
  .ftr-legal a { color: #7B948C; text-decoration: none; }
  .ftr-legal a:hover { color: #fff; text-decoration: underline; }
  @media (max-width: 560px) {
    .ftr-inner { gap: 24px; }
    .ftr-links { margin-left: 0; }
    .links-grid { gap: 8px 32px; }
  }
</style>
