---
// "Sources" section: authoritative primary citations (CFPB, Federal Reserve, Experian, …).
import type { Source } from "../data/types";
interface Props { sources?: Source[]; }
const { sources } = Astro.props as Props;
---
{sources && sources.length > 0 && (
  <section class="section sources">
    <h2>Sources</h2>
    <ul>
      {sources.map((s) => (
        <li><a href={s.url} target="_blank" rel="noopener">{s.label}</a></li>
      ))}
    </ul>
  </section>
)}

<style>
  .sources ul { padding-left: 20px; line-height: 1.7; max-width: 760px; margin: 0; }
  .sources li { margin-bottom: 6px; color: #333; }
  .sources a { color: var(--primary-dark); word-break: break-word; }
</style>
