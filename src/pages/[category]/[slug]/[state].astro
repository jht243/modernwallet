---
// State-subpage route: /{category}/{slug}/{state}/ (e.g. /estate-planning/will-cost-calculator/texas/).
// Generates one page per (spoke × state) combination where the spoke declares `stateVariants`.
// Reuses the spoke template, injects a state law-context section, sibling-state links, and a
// back-link to the parent spoke. Pillar 1 content generation will fill each state page's unique
// title/meta/H1/intro/lawContext via the keyword-gap-pass workflow — the shell renders sensibly
// with template defaults until then.
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LinkCard from "../../../components/LinkCard.astro";
import Byline from "../../../components/Byline.astro";
import Sources from "../../../components/Sources.astro";
import LegalDisclaimer from "../../../components/LegalDisclaimer.astro";
import CalculatorIsland from "../../../components/CalculatorIsland";
import CrossLinks from "../../../components/CrossLinks.astro";
import { SITE, LAST_UPDATED, REVIEWER } from "../../../data/site";
import { SPOKES } from "../../../data/spokes";
import { CALC_BY_ID, isLive, relatedSpokes } from "../../../data/calculators";
import { STATE_BY_SLUG, STATES } from "../../../data/states";
import { getStateOverride } from "../../../data/state-overrides";
import { linkify, plain, paragraphs } from "../../../lib/richtext";
import { titleCase } from "../../../lib/format";
import { personSchema, articleSchema, reviewerPersonSchema } from "../../../lib/jsonld";
import { iconForSpoke } from "../../../data/icons";

// The 4 legal pillars render the attorney-reviewer byline + disclaimer + reviewer JSON-LD.
const LEGAL_PILLARS = new Set(["estate-planning", "probate", "elder-care", "tax-resolution"]);
const TAX_PILLAR = "tax-resolution";

export function getStaticPaths() {
  const paths = [];
  for (const s of SPOKES) {
    if (!s.stateVariants || s.stateVariants.length === 0) continue;
    const c = CALC_BY_ID[s.calculator];
    if (!c || !isLive(c)) continue;
    for (const stateSlug of s.stateVariants) {
      const st = STATE_BY_SLUG[stateSlug];
      if (!st) continue;
      paths.push({
        params: { category: s.calculator, slug: s.slug, state: st.slug },
        props: { entry: s, state: st },
      });
    }
  }
  return paths;
}

const { entry, state } = Astro.props;
const calc = CALC_BY_ID[entry.calculator]!;
const isLegal = LEGAL_PILLARS.has(calc.id);
const disclaimerScope = calc.id === TAX_PILLAR ? "tax" : "legal";
const reviewer = isLegal ? (entry.reviewer ?? REVIEWER) : undefined;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Per-state bespoke content overrides (Phase-3 authored, Phase-4 audited per state page).
// If a state doesn't have overrides yet, sensible templated defaults are used so the shell still
// renders — that page then queues for its own Phase 3 authoring in a follow-on slice.
const override = getStateOverride(entry.slug, state.slug);
const title = override?.title ?? `${titleCase(entry.targetKeyword)} — ${state.name} | ${SITE.name}`;
const metaDescription = (override?.metaDescription ?? `${state.name} ${entry.targetKeyword} estimator. ${entry.metaDescription}`).slice(0, 160);
const h1 = override?.h1 ?? `${entry.h1} — ${state.name}`;
const stateIntro = override?.intro ?? `This page tailors the ${entry.targetKeyword} for ${state.name} residents. ${entry.intro}`;
const stateLawContext = override?.lawContext ?? state.lawContext;
const combinedFaqs = [...(entry.faqs ?? []), ...(override?.extraFaqs ?? [])];
const combinedSources = [...(entry.sources ?? []), ...(override?.extraSources ?? [])];
const sisterStates = STATES.filter((s) => s.slug !== state.slug && (entry.stateVariants ?? []).includes(s.slug)).slice(0, 8);

// ---- JSON-LD ----
const jsonLdFaq = combinedFaqs.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: combinedFaqs.map((f) => ({
        "@type": "Question",
        name: f.question,
        acceptedAnswer: { "@type": "Answer", text: plain(f.answer) },
      })),
    }
  : null;

const jsonLdPerson = personSchema();
const jsonLdReviewerPerson = reviewer ? reviewerPersonSchema(reviewer) : null;
const jsonLdArticle = articleSchema({
  headline: h1,
  description: metaDescription,
  url: canonicalUrl,
  datePublished: LAST_UPDATED,
  sources: combinedSources,
  reviewedBy: reviewer,
});

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: SITE.name, item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: calc.label, item: new URL(`/${calc.id}/`, Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: entry.targetKeyword, item: new URL(`/${calc.id}/${entry.slug}/`, Astro.site).toString() },
    { "@type": "ListItem", position: 4, name: state.name, item: canonicalUrl },
  ],
};

const jsonLdApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: `${entry.targetKeyword} — ${state.name}`,
  description: metaDescription,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Any (web)",
  offers: { "@type": "Offer", price: 0, priceCurrency: "USD" },
  url: canonicalUrl,
};

const related = relatedSpokes(entry, 3);
---
<BaseLayout title={title} description={metaDescription}>
  {jsonLdFaq && <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdPerson)} />
  {jsonLdReviewerPerson && <script type="application/ld+json" set:html={JSON.stringify(jsonLdReviewerPerson)} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />

  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">{SITE.name}</a> <span>/</span>
      <a href={`/${calc.id}/`}>{calc.label}</a> <span>/</span>
      <a href={`/${calc.id}/${entry.slug}/`}>{titleCase(entry.targetKeyword)}</a> <span>/</span>
      <span class="crumb-current">{state.name}</span>
    </nav>

    <header class="hero">
      <h1>{h1}</h1>
      <Byline reviewer={reviewer} />
      {paragraphs(stateIntro).map((para) => <p class="lede" set:html={linkify(para)} />)}
    </header>

    <section class="tool-section" aria-label="Interactive calculator">
      <div class="tool-badge"><span class="dot"></span> Interactive — edit any field</div>
      <CalculatorIsland
        client:only="react"
        calculatorId={entry.islandId ?? calc.islandId}
        initialData={entry.preset}
        heading={entry.toolHeading}
        subheading={entry.toolSubheading}
        mortgageMode={calc.id === "mortgage"}
      />
    </section>

    {stateLawContext && (
      <section class="section">
        <h2>{state.name} law and cost context</h2>
        {paragraphs(stateLawContext).map((para) => <p set:html={linkify(para)} />)}
      </section>
    )}

    <section class="section">
      <h2>How it's calculated</h2>
      {entry.howItWorks.split("\n\n").map((para) => <p set:html={linkify(para)} />)}
    </section>

    <section class="section">
      <h2>Common mistakes to avoid</h2>
      <ul class="mistakes">
        {entry.commonMistakes.map((m) => <li set:html={linkify(m)} />)}
      </ul>
    </section>

    <section class="section">
      <h2>Frequently asked questions</h2>
      <div class="faqs">
        {combinedFaqs.map((f) => (
          <details class="faq">
            <summary><h3>{f.question}</h3></summary>
            <p set:html={linkify(f.answer)} />
          </details>
        ))}
      </div>
    </section>

    {isLegal && <LegalDisclaimer scope={disclaimerScope} />}

    <Sources sources={entry.sources} />

    {sisterStates.length > 0 && (
      <section class="section">
        <h2>See {entry.targetKeyword} for other states</h2>
        <div class="sister-states">
          {sisterStates.map((s) => (
            <a class="pill" href={`/${calc.id}/${entry.slug}/${s.slug}/`}>{s.name}<span class="arrow" aria-hidden="true">→</span></a>
          ))}
        </div>
        <p class="see-all">
          <a href={`/${calc.id}/${entry.slug}/`}>Back to the {titleCase(entry.targetKeyword)} overview →</a>
        </p>
      </section>
    )}

    {related.length > 0 && (
      <section class="section">
        <h2>Related {calc.label.toLowerCase()} calculators</h2>
        <div class="related-grid">
          {related.map((r) => (
            <LinkCard href={`/${r.calculator}/${r.slug}/`} title={r.targetKeyword} meta="Free · instant" icon={iconForSpoke(r.calculator, r.slug)} />
          ))}
        </div>
      </section>
    )}

    <CrossLinks calcId={calc.id} />
  </main>

  <style>
    .page { max-width: 920px; margin: 0 auto; padding: 16px 20px 56px; }
    .crumb { font-size: 0.875rem; color: #666; padding: 8px 0 12px; }
    .crumb a { color: var(--primary-dark); text-decoration: none; }
    .crumb a:hover { text-decoration: underline; }
    .crumb-current { color: #999; }
    .hero { padding: 8px 0 16px; }
    .hero h1 { font-size: 2.3rem; margin: 0 0 14px; line-height: 1.2; }
    .lede { font-size: 1.15rem; color: #3a3a3a; margin: 0 0 14px; line-height: 1.7; }
    .lede:last-of-type { margin-bottom: 0; }
    .tool-section {
      position: relative; margin: 8px 0 18px; padding: 22px;
      background: linear-gradient(180deg, #F4FAF8 0%, #FFFFFF 100%);
      border: 1px solid #D8EEE6; border-radius: 18px;
      box-shadow: 0 12px 32px -18px rgba(0,0,0,0.12);
    }
    .tool-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 0.74rem; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase;
      color: var(--primary-dark); background: #E4F4EF; padding: 4px 10px; border-radius: 999px; margin-bottom: 14px;
    }
    .tool-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--primary); animation: pulse 2s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(14,124,102,0.6); } 70% { box-shadow: 0 0 0 8px rgba(14,124,102,0); } 100% { box-shadow: 0 0 0 0 rgba(14,124,102,0); } }
    .section { padding: 26px 0; border-top: 1px solid #EEF2F0; }
    .section > *:last-child { margin-bottom: 0; }
    .section h2 { font-size: 1.5rem; margin: 0 0 16px; }
    .section p { color: #2c2c2c; font-size: 1.05rem; line-height: 1.85; margin: 0 0 18px; }
    .mistakes { padding-left: 22px; line-height: 1.85; }
    .mistakes li { margin-bottom: 10px; color: #2c2c2c; padding-left: 4px; }
    .faqs { display: flex; flex-direction: column; gap: 8px; }
    .faq { border: 1px solid #eee; border-radius: 8px; padding: 16px 18px; background: #fff; }
    .faq summary { cursor: pointer; list-style: none; }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary h3 { display: inline; font-size: 1.02rem; margin: 0; font-weight: 600; }
    .faq[open] summary h3 { color: var(--primary-dark); }
    .faq p { margin: 12px 0 0; color: #2c2c2c; font-size: 1.02rem; line-height: 1.75; }
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr)); gap: 12px; }
    .sister-states { display: flex; flex-wrap: wrap; gap: 10px; }
    .pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 8px 14px; border-radius: 999px;
      border: 1px solid #D8EEE6; background: #F4FAF8; color: var(--primary-dark);
      text-decoration: none; font-weight: 600; font-size: 0.9rem;
      transition: background 120ms ease, border-color 120ms ease;
    }
    .pill:hover { background: #E4F4EF; border-color: var(--primary); }
    .see-all { margin-top: 14px; font-size: 0.95rem; }
    .see-all a { color: var(--primary-dark); font-weight: 600; text-decoration: none; }
    .see-all a:hover { text-decoration: underline; }
    @media (max-width: 600px) { .hero h1 { font-size: 1.8rem; } .section h2 { font-size: 1.28rem; } .tool-section { padding: 16px; } }
  </style>
</BaseLayout>
