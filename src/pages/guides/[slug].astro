---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Byline from "../../components/Byline.astro";
import Sources from "../../components/Sources.astro";
import { SITE, LAST_UPDATED } from "../../data/site";
import { GUIDES } from "../../data/guides";
import { linkify, plain, paragraphs } from "../../lib/richtext";
import { personSchema, articleSchema } from "../../lib/jsonld";

export function getStaticPaths() {
  return GUIDES.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
const canonicalUrl = new URL(`/guides/${guide.slug}/`, Astro.site).toString();

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: SITE.name, item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Guides", item: new URL("/guides/", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: guide.h1, item: canonicalUrl },
  ],
};
const jsonLdFaq = guide.faqs.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: guide.faqs.map((f) => ({
        "@type": "Question", name: f.question,
        acceptedAnswer: { "@type": "Answer", text: plain(f.answer) },
      })),
    }
  : null;
const jsonLdPerson = personSchema();
const jsonLdArticle = articleSchema({
  headline: guide.h1,
  description: guide.metaDescription,
  url: canonicalUrl,
  datePublished: LAST_UPDATED,
  sources: guide.sources,
});
---
<BaseLayout title={guide.title} description={guide.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  {jsonLdFaq && <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdPerson)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />

  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">{SITE.name}</a> <span>/</span>
      <a href="/guides/">Guides</a> <span>/</span>
      <span class="crumb-current">{guide.h1}</span>
    </nav>

    <header class="hero">
      <h1>{guide.h1}</h1>
      <Byline />
      {paragraphs(guide.intro).map((para) => <p class="lede" set:html={linkify(para)} />)}
    </header>

    <section class="tools" aria-label="Tools for this journey">
      <span class="tools-title">Tools for this journey</span>
      <div class="tool-pills">
        {guide.tools.map((t) => (
          <a class="tool-pill" href={t.href}>{t.label}<span class="arrow" aria-hidden="true">→</span></a>
        ))}
      </div>
    </section>

    {guide.sections.map((s) => (
      <section class="section">
        <h2>{s.heading}</h2>
        {s.body.split("\n\n").map((para) => <p set:html={linkify(para)} />)}
      </section>
    ))}

    <section class="section">
      <h2>Frequently asked questions</h2>
      <div class="faqs">
        {guide.faqs.map((f) => (
          <details class="faq">
            <summary><h3>{f.question}</h3></summary>
            <p set:html={linkify(f.answer)} />
          </details>
        ))}
      </div>
    </section>

    <Sources sources={guide.sources} />
  </main>

  <style>
    .page { max-width: 920px; margin: 0 auto; padding: 16px 20px 56px; }
    .crumb { font-size: 0.875rem; color: #666; padding: 8px 0 12px; }
    .crumb a { color: var(--primary-dark); text-decoration: none; }
    .crumb a:hover { text-decoration: underline; }
    .crumb-current { color: #999; }
    .hero { padding: 8px 0 16px; }
    .hero h1 { font-size: 2.3rem; margin: 0 0 14px; line-height: 1.2; }
    .lede { font-size: 1.15rem; color: #3a3a3a; margin: 0 0 14px; line-height: 1.7; }
    .lede:last-of-type { margin-bottom: 0; }
    .tools { margin: 6px 0 4px; padding: 18px 20px; background: linear-gradient(180deg,#F4FAF8 0%,#FFFFFF 100%); border: 1px solid #D8EEE6; border-radius: 14px; }
    .tools-title { display: block; font-size: 0.74rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--primary-dark); margin-bottom: 12px; }
    .tool-pills { display: flex; flex-wrap: wrap; gap: 10px; }
    .tool-pill { display: inline-flex; align-items: center; gap: 8px; padding: 9px 15px; border-radius: 999px; border: 1px solid #D8EEE6; background: #fff; color: var(--primary-dark); text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: background 120ms ease, border-color 120ms ease, transform 120ms ease; }
    .tool-pill:hover { background: #E4F4EF; border-color: var(--primary); transform: translateY(-1px); }
    .tool-pill .arrow { transition: transform 150ms ease; }
    .tool-pill:hover .arrow { transform: translateX(2px); }
    .section { padding: 26px 0; border-top: 1px solid #EEF2F0; }
    .section > *:last-child { margin-bottom: 0; }
    .section h2 { font-size: 1.5rem; margin: 0 0 16px; }
    .section p { color: #2c2c2c; font-size: 1.05rem; line-height: 1.85; margin: 0 0 18px; }
    .faqs { display: flex; flex-direction: column; gap: 8px; }
    .faq { border: 1px solid #eee; border-radius: 8px; padding: 16px 18px; background: #fff; }
    .faq summary { cursor: pointer; list-style: none; }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary h3 { display: inline; font-size: 1.02rem; margin: 0; font-weight: 600; }
    .faq[open] summary h3 { color: var(--primary-dark); }
    .faq p { margin: 12px 0 0; color: #2c2c2c; font-size: 1.02rem; line-height: 1.75; }
    @media (max-width: 600px) { .hero h1 { font-size: 1.8rem; } .section h2 { font-size: 1.28rem; } }
  </style>
</BaseLayout>
