---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LinkCard from "../../components/LinkCard.astro";
import { SITE } from "../../data/site";
import { CALCULATORS, isLive, spokesForCalc } from "../../data/calculators";
import { iconForSpoke } from "../../data/icons";

const calcs = [...CALCULATORS].sort((a, b) => a.navOrder - b.navOrder);
const canonicalUrl = new URL("/calculators/", Astro.site).toString();

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: SITE.name, item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "All Calculators", item: canonicalUrl },
  ],
};
---
<BaseLayout
  title={`All Financial Calculators — ${SITE.name}`}
  description="Browse every free financial calculator: auto loan, mortgage, retirement, investing, portfolio, rental property, and net worth."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <main class="page">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">{SITE.name}</a> <span>/</span>
      <span class="crumb-current">All Calculators</span>
    </nav>

    <header class="hero">
      <h1>All financial calculators</h1>
      <p class="lede">Every {SITE.name} calculator in one place. Free, instant, and built to show the math behind the answer.</p>
    </header>

    {calcs.map((c) => {
      const spokes = spokesForCalc(c.id);
      const live = isLive(c);
      return (
        <section class="calc-block">
          <div class="calc-head">
            <h2>
              {live ? <a href={`/${c.id}/`}>{c.label} Calculator</a> : <span>{c.label} Calculator</span>}
              {!live && <span class="soon">Coming soon</span>}
            </h2>
          </div>
          <p class="calc-intro">{c.intro}</p>
          {spokes.length > 0 && (
            <div class="grid">
              {spokes.map((s) => (
                <LinkCard href={`/${s.calculator}/${s.slug}/`} title={s.targetKeyword} meta="Free · instant" icon={iconForSpoke(s.calculator, s.slug)} />
              ))}
            </div>
          )}
        </section>
      );
    })}
  </main>

  <style>
    .page { max-width: 1000px; margin: 0 auto; padding: 16px 20px 56px; }
    .crumb { font-size: 0.875rem; color: #666; padding: 8px 0 12px; }
    .crumb a { color: var(--primary-dark); text-decoration: none; }
    .crumb-current { color: #999; }
    .hero { padding: 8px 0 18px; border-bottom: 1px solid #eee; margin-bottom: 8px; }
    .hero h1 { font-size: 2.4rem; margin: 0 0 12px; }
    .lede { font-size: 1.15rem; color: #444; max-width: 760px; line-height: 1.6; margin: 0; }
    .calc-block { padding: 24px 0; border-top: 1px solid #EEF2F0; }
    .calc-head h2 { font-size: 1.5rem; margin: 0 0 8px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .calc-head a { color: var(--text); text-decoration: none; }
    .calc-head a:hover { color: var(--primary-dark); }
    .soon { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #8A7340; background: #FBF4E4; border: 1px solid #F0DEB4; padding: 2px 8px; border-radius: 999px; }
    .calc-intro { color: #444; line-height: 1.65; max-width: 760px; margin: 0 0 14px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 12px; }
    @media (max-width: 600px) { .hero h1 { font-size: 1.9rem; } }
  </style>
</BaseLayout>
